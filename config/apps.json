{
  "applications": [
    {
      "name": "Google Chrome",
      "installerPath": "Chrome/ChromeSetup.exe",
      "silentArgs": "/silent /install",
      "version": "latest",
      "desktopShortcut": {
        "enabled": true,
        "name": "Google Chrome",
        "targetPath": "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"
      },
      "detection": {
        "executablePath": "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"
      }
    },
    {
      "name": "Mozilla Firefox",
      "installerPath": "Firefox/Firefox Installer.exe",
      "silentArgs": "/S",
      "version": "latest",
      "desktopShortcut": {
        "enabled": true,
        "name": "Firefox",
        "targetPath": "C:\\Program Files\\Mozilla Firefox\\firefox.exe"
      },
      "detection": {
        "executablePath": "C:\\Program Files\\Mozilla Firefox\\firefox.exe"
      }
    },
    {
      "name": "Microsoft Office",
      "installerPath": "MicrosoftOffice/setup.exe",
      "silentArgs": "/admin",
      "version": "latest",
      "desktopShortcut": {
        "enabled": true,
        "name": "Microsoft Office",
        "targetPath": "C:\\Program Files\\Microsoft Office\\root\\Office16\\WINWORD.EXE"
      },
      "detection": {
        "executablePath": "C:\\Program Files\\Microsoft Office\\root\\Office16\\WINWORD.EXE"
      }
    },
    {
      "name": "Adobe Reader",
      "installerPath": "AdobeReader/Reader Setup.exe",
      "silentArgs": "/sAll /rs /msi EULA_ACCEPT=YES",
      "version": "latest",
      "desktopShortcut": {
        "enabled": true,
        "name": "Adobe Acrobat Reader",
        "targetPath": "C:\\Program Files\\Adobe\\Acrobat Reader DC\\Reader\\AcroRd32.exe"
      },
      "detection": {
        "executablePath": "C:\\Program Files\\Adobe\\Acrobat Reader DC\\Reader\\AcroRd32.exe"
      }
    },
    {
      "name": "Skype for Business",
      "installerPath": "Skype/SkypeSetup.exe",
      "silentArgs": "/quiet /norestart",
      "version": "latest",
      "desktopShortcut": {
        "enabled": true,
        "name": "Skype for Business",
        "targetPath": "C:\\Program Files\\Microsoft Office\\root\\office16\\lync.exe"
      },
      "detection": {
        "executablePath": "C:\\Program Files\\Microsoft Office\\root\\office16\\lync.exe"
      }
    },
    {
      "name": "Visual Geez",
      "installerPath": "VisualGeez/VisualGeezSetup.exe",
      "silentArgs": "/S",
      "version": "latest",
      "desktopShortcut": {
        "enabled": true,
        "name": "Visual Geez",
        "targetPath": "C:\\Program Files\\Visual Geez\\VisualGeez.exe"
      },
      "detection": {
        "installDir": "C:\\Program Files\\Visual Geez"
      }
    },
    {
      "name": "Kasperskey",
      "installerPath": "Kasperskey/setup.exe",
      "silentArgs": "/s",
      "version": "latest",
      "desktopShortcut": {
        "enabled": true,
        "name": "Kasperskey",
        "targetPath": "C:\\Program Files (x86)\\Kaspersky Lab\\Kaspersky Endpoint Security\\avp.exe"
      },
      "detection": {
        "installDir": "C:\\Program Files (x86)\\Kaspersky Lab"
      }
    }
  ]
